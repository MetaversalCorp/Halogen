material {
    name : PhysicallyBasedMasked,
    shadingModel : lit,
    blending : masked,
    parameters : [
        {
            type : float4,
            name : baseColor
        },
        {
            type : float,
            name : metallic
        },
        {
            type : float,
            name : roughness
        },
        {
            type : float3,
            name : emissive
        },
        {
            type : float,
            name : opacity
        },
        {
            type : sampler2d,
            name : baseColorMap
        },
        {
            type : bool,
            name : hasBaseColorMap
        },
        {
            type : sampler2d,
            name : normalMap
        },
        {
            type : bool,
            name : hasNormalMap
        },
        {
            type : bool,
            name : useAttribute0ForMetallic
        },
        {
            type : bool,
            name : useAttribute1ForRoughness
        }
    ],
    requires : [
        color,
        uv0,
        uv1
    ]
}

fragment {
    void material(inout MaterialInputs material) {
        prepareMaterial(material);
        float4 color = materialParams.baseColor * getColor();
        if (materialParams.hasBaseColorMap) {
            color *= texture(materialParams_baseColorMap, getUV0());
        }
        color.a *= materialParams.opacity;
        material.baseColor = color;

        float m = materialParams.metallic;
        if (materialParams.useAttribute0ForMetallic) {
            m = getUV0().x;
        }
        material.metallic = m;

        float r = materialParams.roughness;
        if (materialParams.useAttribute1ForRoughness) {
            r = getUV1().x;
        }
        material.roughness = r;

        material.emissive = vec4(materialParams.emissive, 0.0);

        if (materialParams.hasNormalMap) {
            vec3 n = texture(materialParams_normalMap, getUV0()).xyz * 2.0 - 1.0;
            material.normal = n;
        }
    }
}
