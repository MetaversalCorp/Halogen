material {
    name : PhysicallyBased,
    shadingModel : lit,
    parameters : [
        {
            type : float4,
            name : baseColor
        },
        {
            type : float,
            name : metallic
        },
        {
            type : float,
            name : roughness
        },
        {
            type : float3,
            name : emissive
        }
    ],
    requires : [
        color
    ]
}

fragment {
    void material(inout MaterialInputs material) {
        prepareMaterial(material);
        material.baseColor = materialParams.baseColor * getColor();
        material.metallic = materialParams.metallic;
        material.roughness = materialParams.roughness;
        material.emissive = vec4(materialParams.emissive, 0.0);
    }
}
