material {
    name : MatteBlend,
    shadingModel : lit,
    blending : transparent,
    parameters : [
        {
            type : float4,
            name : baseColor
        },
        {
            type : float,
            name : opacity
        },
        {
            type : sampler2d,
            name : baseColorMap
        },
        {
            type : bool,
            name : hasBaseColorMap
        },
        {
            type : mat4,
            name : colorTransform
        },
        {
            type : bool,
            name : hasColorTransform
        }
    ],
    requires : [
        color,
        uv0
    ]
}

fragment {
    void material(inout MaterialInputs material) {
        prepareMaterial(material);
        float4 color = materialParams.baseColor * getColor();
        if (materialParams.hasBaseColorMap) {
            color *= texture(materialParams_baseColorMap, getUV0());
        }
        if (materialParams.hasColorTransform) {
            float2 uv = getUV0();
            color = materialParams.colorTransform * float4(uv, 0.0, 1.0);
        }
        color.a *= materialParams.opacity;
        material.baseColor = color;
        material.roughness = 1.0;
        material.metallic = 0.0;
    }
}
